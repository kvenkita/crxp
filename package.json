{
	"name": "crxp",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build:data": "node scripts/build-data.mjs",
		"build:zip": "node scripts/build-data-zip.mjs",
		"build:og": "node scripts/build-og.mjs",
		"build:sitemap": "node scripts/build-sitemap.mjs",
		"build": "npm run build:data && npm run build:zip && vite build",
		"build:full": "npm run build:data && npm run build:zip && npm run build:og && npm run build:sitemap && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@napi-rs/canvas": "^0.1.65",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/svelte": "^5.2.8",
		"jsdom": "^26.1.0",
		"jszip": "^3.10.1",
		"mapshaper": "^0.7.33",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"d3-array": "^3.2.4",
		"d3-color": "^3.1.0",
		"d3-geo": "^3.1.1",
		"d3-interpolate": "^3.0.1",
		"d3-scale": "^4.0.2",
		"d3-scale-chromatic": "^3.1.0",
		"dompurify": "^3.2.7",
		"fuse.js": "^7.1.0",
		"maplibre-gl": "^5.9.0",
		"marked": "^15.0.12",
		"pmtiles": "^4.3.0"
	}
}
